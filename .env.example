# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gsa_db
DB_USER=gsa_user
DB_PASSWORD=changeme
DB_SSL=false

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3001

# Porta pubblica del container nginx (default 80)
HTTP_PORT=80

# Segreto per firmare i JWT — generare con: openssl rand -hex 64
JWT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Credenziali dalla Google Cloud Console (APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── URL pubblici (obbligatori in produzione) ──────────────────────────────────
# URL del frontend (es. https://gsa.mio-dominio.it)
FRONTEND_URL=http://localhost:5173

# URL pubblico del backend — deve corrispondere al redirect_uri in Google Console
# (es. https://gsa.mio-dominio.it  oppure  https://gsa.mio-dominio.it)
# Il callback registrato in Google deve essere: ${BACKEND_URL}/auth/google/callback
BACKEND_URL=http://localhost:3001

# ── Email admin iniziale ──────────────────────────────────────────────────────
# Al primo login con questo account viene assegnato automaticamente il ruolo admin
ADMIN_EMAIL=

# ── Upload e OCR ──────────────────────────────────────────────────────────────
# Dimensione massima upload file (default 20 MB)
MAX_FILE_SIZE=20971520

# Soglia caratteri sotto cui attiva OCR (default 120)
OCR_MIN_CHARS=120

# Lingua Tesseract per OCR
TESSERACT_LANG=ita

# ── Storage (opzionale — default: ./storage/) ─────────────────────────────────
# STORAGE_PATH=/percorso/assoluto/storage/pdf
# ARCHIVIO_PATH=/percorso/assoluto/storage/archivio
