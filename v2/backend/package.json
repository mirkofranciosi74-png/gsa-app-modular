{
  "name": "gsa-v2-backend",
  "version": "2.0.0",
  "description": "GSA v2 — backend DDD Node.js + PostgreSQL",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "lsof -ti :3002 | xargs kill -9 2>/dev/null; nodemon server.js",
    "db:migrate": "node ../../db/migrations/v2/run.js",
