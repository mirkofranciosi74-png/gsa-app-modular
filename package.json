{
  "name": "gsa-app",
  "version": "2.0.0",
  "description": "Gestione Spese Appartamenti — monorepo v1 + v2",
  "private": true,
  "scripts": {
    "v1:dev":       "cd v1/backend && node -e \"import('dotenv/config')\" && nodemon server.js",
    "v2:dev":       "cd v2/backend && node -e \"import('dotenv/config')\" && nodemon server.js",
    "v1:frontend":  "cd v1/frontend && npm run dev",
    "v2:frontend":  "cd v2/frontend && npm run dev",
    "db:migrate:v1": "cd v1/backend && node ../../db/migrations/v1/run.js",
    "db:migrate:v2": "node db/migrations/v2/run.js",
    "test:v2":      "cd v2/backend && node --test __tests__/domain/Persona.test.js __tests__/domain/MotoreRiparto.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
